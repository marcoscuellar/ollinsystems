# Copy this to .env.local for local dev, or set these in your hosting
# provider's environment variables (e.g. Vercel project settings) for
# production. Nothing here is required to run the app in pure demo mode —
# without these, real sign-in/signup is disabled and the app degrades
# gracefully instead of crashing.

# Signs the login session (Auth.js/NextAuth). Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Upstash Redis (Vercel KV) — where real user accounts/passwords live.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Comma-separated emails that always get approved (real access + AI
# features), regardless of what's stored on their account record. Not limited
# to your own team — add an agency's email here once they've signed up (or
# paid) to flip them from demo-only to real access. Put your own email here
# first. Without this set, EVERY account (including yours) is demo-only.
APPROVED_EMAILS=

# Powers the AI features (script rewrite, etc.). Restricted to approved
# accounts at the API route level.
ANTHROPIC_API_KEY=
# Optional — defaults to claude-sonnet-4-5 if unset.
ANTHROPIC_MODEL=
